# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_SHEET_CSV_URL: The public CSV export URL or Sheet ID.
# Format: https://docs.google.com/spreadsheets/d/ID/export?format=csv
VITE_SHEET_CSV_URL="https://docs.google.com/spreadsheets/d/e/2PACX-1vTblBqLl6Bcjjvr7jAG-q_mUIiPjyi55_7F0DgUDIgs6jVYVwTcaHVhomlRpXilfIr4VUB99F2xBa2_/pub?output=csv"
